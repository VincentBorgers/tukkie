APP_NAME=Tukkie
ENVIRONMENT=development
HOST=127.0.0.1
PORT=8000
DEFAULT_LANGUAGE=nl-NL
DB_PATH=config/data/tukkie.db
CHROMA_PATH=config/chroma
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
ALLOW_FALLBACK_INTEGRATIONS=false
USE_SAMPLE_SEED_DATA=false
MEMORY_ENCRYPTION_KEY=
TOOL_TIMEOUT_SECONDS=10
ENABLE_VOICE_BLUEPRINT=true
VOICE_INPUT_ENABLED=true
VOICE_AUTO_SPEAK=false
VOSK_MODEL_PATH=config/models/vosk-model-small-nl-0.22
PIPER_BINARY_PATH=.venv/Scripts/piper.exe
PIPER_VOICE_MODEL_PATH=config/models/piper/nl_NL-ronnie-medium.onnx
PIPER_VOICE_CONFIG_PATH=config/models/piper/nl_NL-ronnie-medium.onnx.json
DEVICE_REFRESH_INTERVAL_SECONDS=30
CRITICAL_CONFIRMATION_WINDOW_SECONDS=300
VITE_API_BASE_URL=http://localhost:8000
DEFAULT_PROFILE_NAME=Household
DEFAULT_HOME_CITY=
DEFAULT_WAKE_WORD=tukkie
ASSISTANT_CONFIG_PATH=config/assistant.yaml
PROFILE_CONFIG_PATH=config/profile.yaml
ROOMS_CONFIG_PATH=config/rooms.yaml
DEVICES_CONFIG_PATH=config/devices.yaml
SCENES_CONFIG_PATH=config/scenes.yaml
AUTOMATIONS_CONFIG_PATH=config/automations.yaml
RING_USERNAME=
RING_PASSWORD=
RING_2FA_CODE=
RING_TOKEN_CACHE_PATH=config/data/ring-token.json
